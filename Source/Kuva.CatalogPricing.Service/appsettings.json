{
  "Service": {
    "Name": "Kuva.CatalogPricing.Service"
  },
  "ConnectionStrings": {
    "CatalogPricingDatabase": ""
  },
  "Jwt": {
    "Issuer": "kuva-auth",
    "Audience": "kuva-apis"
  },
  "CatalogPricing": {
    "DefaultCurrency": "BRL",
    "CacheTtlSeconds": 60,
    "MaxQuoteItems": 50,
    "MaxQuantityPerItem": 1000
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
